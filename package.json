{
  "name": "longer-agent",
  "version": "0.1.0",
  "description": "Multi-agent CLI with proactive context summarization",
  "type": "module",
  "license": "MIT",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "bin": {
    "longeragent": "./dist/cli.js"
  },
  "files": [
    "dist/",
    "agent_templates/",
    "prompts/",
    "skills/",
    "configExample.yaml",
    "LICENSE",
    "README.md"
  ],
  "keywords": [
    "ai",
    "agent",
    "cli",
    "llm",
    "multi-agent",
    "context-management",
    "summarization"
  ],
  "scripts": {
    "build": "tsc -p tsconfig.build.json",
    "dev": "tsx src/cli.ts",
    "test": "vitest run",
    "test:watch": "vitest",
    "typecheck": "tsc --noEmit",
    "prepublishOnly": "pnpm build && pnpm test"
  },
  "engines": {
    "node": ">=20.0.0"
  },
  "dependencies": {
    "@anthropic-ai/sdk": "^0.61.0",
    "@inquirer/prompts": "^8.3.0",
    "commander": "^12.0.0",
    "gpt-tokenizer": "^3.4.0",
    "ink": "^6.8.0",
    "js-yaml": "^4.1.0",
    "marked": "^15.0.0",
    "marked-terminal": "^7.0.0",
    "markitdown-ts": "^0.0.10",
    "openai": "^4.90.0",
    "react": "^19.2.4"
  },
  "devDependencies": {
    "@types/js-yaml": "^4.0.9",
    "@types/node": "^22.0.0",
    "@types/react": "^19.2.14",
    "tsx": "^4.19.0",
    "typescript": "^5.7.0",
    "vitest": "^3.0.0"
  },
  "optionalDependencies": {
    "@modelcontextprotocol/sdk": "^1.12.0"
  }
}
